-- SLIDE
local function slideTabs(target)
    if switching then return end
    switching = true

    local goalMain = target == "Settings" and UDim2.new(-1,0,0,50) or UDim2.new(0,0,0,50)
    local goalSettings = target == "Settings" and UDim2.new(0,0,0,50) or UDim2.new(1,0,0,50)

    TweenService:Create(main, TweenInfo.new(0.3), {Position = goalMain}):Play()
    TweenService:Create(settings, TweenInfo.new(0.3), {Position = goalSettings}):Play()

    task.delay(0.3, function()
        switching = false
    end)
end

mainBtn.MouseButton1Click:Connect(function()
    slideTabs("Main")
end)

settingsBtn.MouseButton1Click:Connect(function()
    slideTabs("Settings")
end)

-- SLIDER
local function slider(parent,name,min,max,setting,y)
    local holder = Instance.new("Frame", parent)
    holder.Size = UDim2.new(1,0,0,60)
    holder.Position = UDim2.new(0,0,0,y)
    holder.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", holder)
    label.Size = UDim2.new(1,0,0,20)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1,1,1)

    local bar = Instance.new("Frame", holder)
    bar.Size = UDim2.new(1,0,0,8)
    bar.Position = UDim2.new(0,0,0,35)
    bar.BackgroundColor3 = Color3.fromRGB(60,60,60)
    Instance.new("UICorner", bar)

    local fill = Instance.new("Frame", bar)
    fill.BackgroundColor3 = PURPLE
    Instance.new("UICorner", fill)

    local knob = Instance.new("Frame", bar)
    knob.Size = UDim2.new(0,14,0,14)
    knob.BackgroundColor3 = PURPLE
    Instance.new("UICorner", knob)

    local dragging=false

    local function update(x)
        local pct = math.clamp((x-bar.AbsolutePosition.X)/bar.AbsoluteSize.X,0,1)
        fill.Size = UDim2.new(pct,0,1,0)
        knob.Position = UDim2.new(pct,-7,0.5,-7)

        local raw = min + (max - min) * pct
         local val = math.round(raw * 10) / 10 -- 1 decimal place
        Settings[setting]=val

        label.Text = name.." ("..string.format("%.1f", val)..")"
    end

    -- DONT TOUCH
    task.wait()
    update(bar.AbsolutePosition.X + (Settings[setting]-min)/(max-min)*bar.AbsoluteSize.X)

    bar.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end
    end)

    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)

    UIS.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            update(i.Position.X)
        end
    end)
end

