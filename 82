--// AIMBOT ( DONT TOUCH )
local function getClosest()
    local closest = nil
    local shortest = Settings.FOV

    for _,v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild(Settings.AimPart) then
            local pos,visible = camera:WorldToViewportPoint(v.Character[Settings.AimPart].Position)

            if visible then
                local dist = (Vector2.new(pos.X,pos.Y) - UIS:GetMouseLocation()).Magnitude

                if dist < shortest then
                    shortest = dist
                    closest = v
                end
            end
        end
    end

    return closest
end

RS.RenderStepped:Connect(function()
    if holding then
        local target = getClosest()

        if target and target.Character then
            local part = target.Character:FindFirstChild(Settings.AimPart)

            if part then
                local camCF = camera.CFrame
                local newCF = CFrame.new(camCF.Position, part.Position)

                camera.CFrame = camCF:Lerp(newCF, Settings.Smoothness / 100)
            end
        end
    end
end)

--// INPUT (AIM + UI TOGGLE)
UIS.InputBegan:Connect(function(input,gp)
    if gp then return end

    -- AIM (keyboard + mouse)
    if input.KeyCode == Settings.AimKey 
    or input.UserInputType == Settings.AimKey then
        holding = true
    end

    -- UI toggle (keyboard only)
    if input.KeyCode == Settings.ToggleKey then
        uiVisible = not uiVisible
        gui.Enabled = uiVisible
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.KeyCode == Settings.AimKey 
    or input.UserInputType == Settings.AimKey then
        holding = false
    end
end)

--// SETTINGS: KEYBINDS
local function keybind(parent,name,setting,y)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1,0,0,40)
    btn.Position = UDim2.new(0,0,0,y)
    btn.BackgroundColor3 = PURPLE
    btn.TextColor3 = Color3.new(0,0,0)

    local function getName(input)
        if typeof(input) == "EnumItem" then
            return input.Name
        end
        return "None"
    end

    btn.Text = name..": "..getName(Settings[setting])

    btn.MouseButton1Click:Connect(function()
        btn.Text = name..": ..."

        local conn
        conn = UIS.InputBegan:Connect(function(input, gp)
            if gp then return end

            -- ACCEPT BOTH KEYBOARD + MOUSE
            if input.UserInputType == Enum.UserInputType.Keyboard then
                Settings[setting] = input.KeyCode
            elseif input.UserInputType.Name:find("Mouse") then
                Settings[setting] = input.UserInputType
            else
                return
            end

            btn.Text = name..": "..getName(Settings[setting])
            conn:Disconnect()
        end)
    end)
end

